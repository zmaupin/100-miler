# Copy to `.env` for local dev with `netlify dev`. `.env` is gitignored — never commit secrets.
# These are read by the Netlify Functions only; they are NOT exposed to the browser.

# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=254626
STRAVA_CLIENT_SECRET=your_client_secret_here

# Optional: override the public Client ID baked into the frontend build.
# Defaults to 254626 in code, so this is usually unnecessary.
# VITE_STRAVA_CLIENT_ID=254626
